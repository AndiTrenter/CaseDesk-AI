# ============================================
# CaseDesk AI - Konfiguration
# ============================================
# Kopiere diese Datei:  cp .env.example .env
# Dann anpassen:        nano .env
# ============================================

# --- MongoDB (Pflicht) ---
MONGO_USER=casedesk
MONGO_PASSWORD=change-me-to-a-strong-password
DB_NAME=casedesk

# --- Sicherheit (Pflicht) ---
# Generiere einen zufaelligen Schluessel:
#   openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret

# --- Port (Pflicht) ---
# Unter diesem Port ist die Web-Oberflaeche erreichbar
FRONTEND_PORT=9090

# --- KI-Anbieter (Pflicht) ---
# Moegliche Werte: "openai" oder "ollama"
# Standard: openai (kein lokaler LLM-Server noetig)
AI_PROVIDER=openai

# --- OpenAI (Pflicht wenn AI_PROVIDER=openai) ---
# API-Key von https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Ollama (nur wenn AI_PROVIDER=ollama) ---
# Ollama muss separat gestartet werden:
#   docker compose -f docker-compose.unraid.yml --profile ollama up -d
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
