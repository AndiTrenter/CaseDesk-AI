# ============================================
# CaseDesk AI - Konfiguration
# ============================================
# Installation:
#   1. cp .env.example .env
#   2. nano .env  (Werte anpassen)
#   3. docker compose -f docker-compose.unraid.yml up -d
#
# Web-Oberfläche: http://[DEINE-IP]:9090
# ============================================

# --- Datenbank ---
# Name der MongoDB-Datenbank
DB_NAME=casedesk

# MongoDB Version (Standard: 4.4)
# HINWEIS: MongoDB 5.0+ benötigt AVX-Support in der CPU.
# Falls Ihre CPU kein AVX unterstützt (ältere CPUs, einige Unraid-Server),
# belassen Sie diese Einstellung bei 4.4
MONGO_VERSION=4.4

# --- Sicherheit (PFLICHT - ÄNDERN!) ---
# Generiere einen zufälligen Schlüssel:
#   openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret

# --- Port ---
# Unter diesem Port ist die Web-Oberfläche erreichbar
FRONTEND_PORT=9090

# --- KI-Anbieter (PFLICHT) ---
# Mögliche Werte: "openai" oder "ollama"
AI_PROVIDER=openai

# --- OpenAI (wenn AI_PROVIDER=openai) ---
# API-Key von https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Ollama (wenn AI_PROVIDER=ollama) ---
# Ollama muss mit --profile ollama gestartet werden:
#   docker compose -f docker-compose.unraid.yml --profile ollama up -d
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
