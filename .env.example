# ============================================
# CaseDesk AI - Environment Configuration
# ============================================
# Copy this file to .env before running:
#   cp .env.example .env
#   docker compose up -d
# ============================================

# --- MongoDB ---
MONGO_USER=casedesk
MONGO_PASSWORD=change-me-to-a-strong-password
DB_NAME=casedesk

# --- Security ---
# IMPORTANT: Generate a random string for production!
# Example: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret

# --- Ports ---
FRONTEND_PORT=9090
BACKEND_PORT=8001
MONGO_PORT=27017

# --- AI Configuration ---
# Option A: Local AI via Ollama (default, no key needed)
#   Set ENABLE_OLLAMA=true and leave OPENAI_API_KEY empty
#
# Option B: OpenAI (cloud AI)
#   Set ENABLE_OLLAMA=false and provide your API key
#
ENABLE_OLLAMA=true
OPENAI_API_KEY=

# --- Ollama Settings (only if ENABLE_OLLAMA=true) ---
OLLAMA_MODEL=llama3.2
