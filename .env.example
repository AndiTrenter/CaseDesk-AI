# CaseDesk AI - Environment Configuration
# Copy this file to .env and adjust values as needed

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_USER=casedesk
POSTGRES_PASSWORD=casedesk_secret_change_me
POSTGRES_DB=casedesk

# ===========================================
# SECURITY
# ===========================================
# IMPORTANT: Change this to a secure random string in production!
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production

# ===========================================
# AI CONFIGURATION
# ===========================================
# Ollama runs locally by default (no API key needed)
# Add OpenAI key only if you want to use OpenAI as alternative
OPENAI_API_KEY=

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# URL where the backend API is accessible from the frontend
FRONTEND_BACKEND_URL=http://localhost:8001

# ===========================================
# OCR CONFIGURATION
# ===========================================
OCR_ENABLED=true

# ===========================================
# OPTIONAL: GPU SUPPORT
# ===========================================
# Set to true if you have NVIDIA GPU for faster AI processing
# GPU_ENABLED=true
