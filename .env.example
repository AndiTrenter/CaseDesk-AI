# CaseDesk AI - Environment Configuration
# Copy this file to .env and adjust values as needed

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_USER=casedesk
POSTGRES_PASSWORD=casedesk_secret_change_me
POSTGRES_DB=casedesk

# ===========================================
# SECURITY
# ===========================================
# IMPORTANT: Change this to a secure random string in production
SECRET_KEY=your-super-secret-key-change-in-production

# ===========================================
# AI CONFIGURATION (Optional)
# ===========================================
# Leave empty for local-only mode
# Add your OpenAI API key to enable external AI features
OPENAI_API_KEY=

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# URL where the backend API is accessible from the frontend
FRONTEND_BACKEND_URL=http://localhost:8001

# ===========================================
# OCR CONFIGURATION
# ===========================================
OCR_ENABLED=true

# ===========================================
# EMAIL CONFIGURATION (Optional)
# ===========================================
# Configure in the web interface after installation
