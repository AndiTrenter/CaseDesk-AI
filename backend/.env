# Development environment - Used during Emergent development
# For production, use docker-compose.yml

# Database (using MongoDB for development compatibility)
MONGO_URL="mongodb://localhost:27017"
DB_NAME="casedesk_dev"
CORS_ORIGINS="*"

# PostgreSQL (for production Docker deployment)
DATABASE_URL=postgresql://casedesk:casedesk_secret@localhost:5432/casedesk

# Security
SECRET_KEY=dev-secret-key-change-in-production

# AI Configuration (Optional - leave empty for local-only mode)
OPENAI_API_KEY=

# OCR Service
OCR_SERVICE_URL=http://localhost:8002

# Upload directory
UPLOAD_DIR=./uploads
